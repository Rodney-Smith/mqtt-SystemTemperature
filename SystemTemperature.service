[Unit]
Description=RPi CPU Temperature reporting over MQTT
After = network.target

[Service]
Type=simple
ExecStart=/usr/bin/env python3 /opt/scripts/mqtt-SystemTemperature/mqtt_systemp.py
WorkingDirectory=/opt/scripts/mqtt-SystemTemperature
TimeoutStartSec=120
TimeoutStopSec=30
Restart=always
RestartSec=10
WatchdogSec=60
User=pi

[Install]
WantedBy=multi-user.target
